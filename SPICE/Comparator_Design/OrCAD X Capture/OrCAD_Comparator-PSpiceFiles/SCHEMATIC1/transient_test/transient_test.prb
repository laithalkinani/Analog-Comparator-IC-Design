[DISPLAYS]
BEGIN DISPLAY LAST SESSION
ANALYSIS TRANSIENT_ANALYSIS
SYMBOL ALWAYS
TRACECOLORSCHEME NORMAL
BEGIN ANAPLOT 1
ACTIVE
XBASE
BEGIN XAXIS
XAXISUSERNAME 0 (null)
TEXT Time
RANGEFLAG AUTO
TYPE LINEAR
UNIT s
BEGIN GRIDS
AUTOMATIC
MAJORNUMBERS
MAJORSTYLE LINES
MAJORPATTERN SOLID
MINORSTYLE LINES
MINORPATTERN DOT
END GRIDS
END XAXIS
BEGIN YAXIS 1
YAXISSIDE LEFT
ACTIVE
RANGEFLAG AUTO
TYPE LINEAR
UNIT x
BEGIN GRIDS
AUTOMATIC
MAJORNUMBERS
MAJORSTYLE LINES
MAJORPATTERN SOLID
MINORSTYLE LINES
MINORPATTERN DOT
END GRIDS
BEGIN TRACE V(M2:d)
MARKERID 1
TRACEADDEXT
END TRACE V(M2:d)
BEGIN TRACE V(M1:g)
MARKERID 2
TRACEADDEXT
END TRACE V(M1:g)
BEGIN TRACE ID(M6)
MARKERID 3
TRACEADDEXT
END TRACE ID(M6)
BEGIN TRACE (IS(M3)+IB(M3))
MARKERID 4
TRACEADDEXT
END TRACE (IS(M3)+IB(M3))
BEGIN TRACE V(IREF:-)
MARKERID 5
TRACEADDEXT
END TRACE V(IREF:-)
BEGIN TRACE V(M9:s)
MARKERID 6
TRACEADDEXT
END TRACE V(M9:s)
END YAXIS 1
END ANAPLOT 1
END DISPLAY LAST SESSION
